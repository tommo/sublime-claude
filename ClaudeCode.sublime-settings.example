{
    // Path to Python 3.10+ interpreter for the bridge process
    // Must have claude-agent-sdk installed: pip install claude-agent-sdk
    "python_path": "python3",

    // Default model when no profile is selected
    // Options: "opus", "sonnet", "haiku"
    // If not set, defaults to SDK default (sonnet)
    "default_model": "opus",

    // Default provider (backend) for a bare "New Session". Defaults to "claude"
    // (official Anthropic). Set to a built-in (codex/copilot/pi/dsr/grok) or a custom
    // provider key from custom_providers. Set via "Claude: Set Default Provider".
    // "default_backend": "claude",

    // --- Grok (xAI) backend ---
    // Uses xAI via a bundled Anthropic<->xAI proxy (grok_proxy/), authenticated
    // with a SuperGrok OAuth login. First run: Command Palette -> "Claude: Grok
    // Login" (opens a browser). After login, "Grok" appears in the backend
    // picker. The proxy is auto-spawned on session start and survives sleep.
    // "grok_proxy_port": 8787,             // localhost port for the proxy
    // "grok_proxy_auth_token": "",         // bearer token clients present; auto-generated if blank
    // "grok_proxy_base_url": "https://api.x.ai/v1",  // xAI upstream
    // "grok_proxy_data_dir": "~/.claude/grok_proxy", // token + log + pid storage

    // Tools Claude is allowed to use without confirmation
    // Common tools: Read, Write, Edit, Bash, Glob, Grep, WebFetch, WebSearch
    "allowed_tools": ["Read", "Write", "Edit", "Bash", "Glob", "Grep"],

    // Permission mode for tool execution
    // Options:
    //   "default"           - Confirm each tool use
    //   "acceptEdits"       - Auto-accept file edits
    //   "plan"              - Planning mode only
    //   "bypassPermissions" - Allow all tools (use with caution)
    "permission_mode": "acceptEdits",

    // Sandbox mode - restricts command execution for safety
    // When enabled, bash commands run in isolated environment
    "sandbox": {
        // Enable sandbox mode
        "enabled": false,

        // Auto-approve bash commands when sandboxed (safe since restricted)
        "autoAllowBashIfSandboxed": true,

        // Commands that always bypass sandbox (e.g., docker needs host access)
        "excludedCommands": ["docker", "podman"],

        // Allow Claude to request running specific commands unsandboxed
        // Falls back to permission system for approval
        "allowUnsandboxedCommands": false,

        // Network restrictions within sandbox
        "network": {
            // Allow binding to local ports (for dev servers)
            "allowLocalBinding": true,

            // Specific unix sockets to allow (e.g., docker socket)
            "allowUnixSockets": ["/var/run/docker.sock"]
        }
    },

    // Custom Anthropic-compatible providers — arbitrary endpoints that speak
    // the Anthropic API (DeepSeek, GLM, Kimi, Qwen, OpenRouter, …). Same env
    // surface as the ccm model-switcher. Manage via the UI:
    //   Command Palette → "Claude: Manage Anthropic Providers"
    //
    // Fields per provider:
    //   label / abbrev         display label + tab abbreviation (optional)
    //   base_url               Anthropic-compatible endpoint (required)
    //   auth_token             inline token (blank → read from auth_env_var)
    //   auth_env_var                env var to read the token from
    //   opus_model / sonnet_model / haiku_model   alias → model id
    //   auth_via_api_key       true → auth via ANTHROPIC_API_KEY (default: AUTH_TOKEN)
    //   extra_env              optional extra env vars (dict, added as defaults)
    //
    // "custom_providers": {
    //     "deepseek": {
    //         "label": "DeepSeek",
    //         "abbrev": "DS",
    //         "base_url": "https://api.deepseek.com/anthropic",
    //         "auth_env_var": "DEEPSEEK_API_KEY",
    //         "opus_model": "deepseek-v4-pro[1m]",
    //         "sonnet_model": "deepseek-v4-pro[1m]",
    //         "haiku_model": "deepseek-v4-flash",
    //         "subagent_model": "deepseek-v4-flash",
    //         "extra_env": {
    //             "CLAUDE_CODE_EFFORT_LEVEL": "max"
    //         }
    //     }
    // }
}
