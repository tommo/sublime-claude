[
    {
        "id": "tools",
        "children": [
            {
                "caption": "Claude Code",
                "children": [
                    {
                        "caption": "Start Session",
                        "command": "claude_code_start"
                    },
                    {
                        "caption": "Query Claude",
                        "command": "claude_code_query"
                    },
                    {
                        "caption": "Query Selection",
                        "command": "claude_code_query_selection"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Toggle Output",
                        "command": "claude_code_toggle"
                    },
                    {
                        "caption": "Clear Output",
                        "command": "claude_code_clear"
                    },
                    {
                        "caption": "Interrupt",
                        "command": "claude_code_interrupt"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Stop Session",
                        "command": "claude_code_stop"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Settings...",
                        "command": "edit_settings",
                        "args": {
                            "base_file": "${packages}/ClaudeCode/ClaudeCode.sublime-settings",
                            "default": "// Claude Code Settings\n// See default settings on the left for available options\n{\n}\n"
                        }
                    },
                    {
                        "caption": "Output Settings...",
                        "command": "edit_settings",
                        "args": {
                            "base_file": "${packages}/ClaudeCode/ClaudeOutput.sublime-settings",
                            "default": "// Claude Output View Settings\n// See default settings on the left for available options\n{\n}\n"
                        }
                    },
                    { "caption": "-" },
                    {
                        "caption": "Grok: New Session",
                        "command": "grok_start"
                    },
                    {
                        "caption": "Grok (Claude Code): New Session",
                        "command": "grok_cc_start"
                    },
                    {
                        "caption": "Grok: Login…",
                        "command": "grok_login"
                    },
                    { "caption": "-" },
                    {
                        "caption": "Manage Anthropic Providers…",
                        "command": "claude_manage_providers"
                    },
                    {
                        "caption": "Set Default Provider…",
                        "command": "claude_set_default_provider"
                    }
                ]
            }
        ]
    }
]
